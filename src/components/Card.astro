---
// 汎用カード／コールアウト（common.css の .card）
// variant: "" | "v"（朱色）| "amber"（橙）
interface Props {
  variant?: '' | 'v' | 'amber';
  label?: string;
}
const { variant = '', label } = Astro.props;
const cls = ['card', variant].filter(Boolean).join(' ');
---
<div class={cls}>
  {label && <span class="card-label">{label}</span>}
  <slot />
</div>
