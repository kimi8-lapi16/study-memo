---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, formatDate } from '../lib/utils';

const notes = await getCollection('notes', ({ data }) => !data.draft);
notes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const studyNotes = notes.filter((n) => n.data.category !== 'NEWS');
const newsNotes = notes.filter((n) => n.data.category === 'NEWS');
---
<BaseLayout
  title="study-memo｜勉強会メモ アーカイブ"
  description="勉強会で学んだことを書き溜めておく場所。"
>
  <header class="hero">
    <div class="wrap">
      <p class="kicker">study-memo</p>
      <h1 class="title">勉強会で学んだことの、置き場所。</h1>
      <p class="sub">参加した勉強会・読んだ論文・触ってみた技術のメモと、毎朝自動収集しているITニュースのダイジェスト。あとでパッと見返せるように書き溜めている。</p>
    </div>
  </header>

  <main>
    <div class="wrap">
      <input type="radio" name="tab" id="tab-study" class="tab-radio" checked />
      <input type="radio" name="tab" id="tab-news" class="tab-radio" />

      <div class="tabs">
        <label for="tab-study">勉強メモ<span class="count">{studyNotes.length}</span></label>
        <label for="tab-news">ニュース<span class="count">{newsNotes.length}</span></label>
      </div>

      {[
        { key: 'study', items: studyNotes, useListTitle: true },
        { key: 'news', items: newsNotes, useListTitle: false },
      ].map(({ key, items, useListTitle }) => (
        <ul class={`entries entries-${key}`}>
          {items.length === 0 ? (
            <li class="empty">まだ記事がありません</li>
          ) : (
            items.map((note) => (
              <li>
                <a class="entry" href={withBase(`notes/${note.id}/`)}>
                  <div class="e-meta">
                    <span>{formatDate(note.data.date)}</span>
                    <span>{note.data.category}</span>
                  </div>
                  <div class="e-title">
                    {useListTitle ? (note.data.listTitle ?? note.data.title) : note.data.title}
                  </div>
                  <div class="e-summary">{note.data.summary}</div>
                </a>
              </li>
            ))
          )}
        </ul>
      ))}
    </div>
  </main>

  <footer>
    <div class="wrap">
      <a href="https://github.com/kimi8-lapi16/study-memo">github.com/kimi8-lapi16/study-memo</a>
    </div>
  </footer>
</BaseLayout>

<style is:global>
  /* ---------- INDEX PAGE SPECIFIC STYLES ---------- */
  body { min-height: 100vh; }
  header.hero { padding: 72px 0 44px; }

  main { padding: 8px 0 96px; }

  /* ---------- TABS（ラジオ + CSS、JSなし） ---------- */
  .tab-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .tabs {
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 8px;
  }

  .tabs label {
    padding: 14px 18px 12px;
    font-size: 0.95rem;
    color: var(--ink-faint);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    user-select: none;
  }

  .tabs label:hover { color: var(--ink); }

  .tabs .count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    margin-left: 8px;
    color: var(--ink-faint);
  }

  #tab-study:checked ~ .tabs label[for="tab-study"],
  #tab-news:checked ~ .tabs label[for="tab-news"] {
    color: var(--ink);
    font-weight: 700;
    border-bottom-color: var(--ink);
  }

  #tab-study:focus-visible ~ .tabs label[for="tab-study"],
  #tab-news:focus-visible ~ .tabs label[for="tab-news"] {
    outline: 2px solid var(--acc);
    outline-offset: -2px;
  }

  ul.entries { list-style: none; display: none; }

  #tab-study:checked ~ .entries-study,
  #tab-news:checked ~ .entries-news { display: block; }

  /* ---------- ENTRY LIST ---------- */
  .entry {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 24px 4px;
    border-bottom: 1px solid var(--line);
  }
  .entry .e-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    margin-bottom: 8px;
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .entry .e-title {
    font-weight: 700;
    font-size: 1.12rem;
    line-height: 1.55;
    margin-bottom: 6px;
    color: var(--ink);
  }
  .entry:hover .e-title { color: var(--acc); }
  .entry .e-summary {
    color: var(--ink-dim);
    font-size: 0.9rem;
    line-height: 1.8;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .empty {
    text-align: center;
    color: var(--ink-faint);
    font-size: 0.9rem;
    padding: 60px 0;
  }

  /* ---------- INDEX FOOTER ---------- */
  footer {
    border-top: 1px solid var(--line);
    padding: 32px 0 56px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--ink-faint);
  }
  footer a { color: var(--ink-dim); text-decoration: none; }
  footer a:hover { color: var(--acc); }
</style>
